### Variáveis de Ambiente (ajuste a baseUrl se necessário)
@baseUrl = https://detector-50pn.onrender.com
@token = 
@cartaoId =
@transacaoId =

### ===================================================
### PASSO 1: REGISTRAR (Cadastro)
### ===================================================
POST {{baseUrl}}/api/usuarios
Content-Type: application/json

{
    "nome": "Usuario Teste HTTP Completo",
    "email": "teste.http.completo@valido.com",
    "senha": "senha123"
}

### ===================================================
### PASSO 2: LOGIN (Obter Token)
### ===================================================
# @name login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
    "email": "teste.http.completo@valido.com",
    "senha": "senha123"
}

> {%
    client.global.set("token", response.body.token);
    client.log("Token salvo: " + response.body.token);
%}

### ===================================================
### PASSO 3: CRIAÇÃO DE CARTÃO
### ===================================================
# @name addCard
POST {{baseUrl}}/api/cartoes
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "numero": "4242424242424242",
    "validade": "12/30",
    "nomeTitular": "Usuario Teste HTTP Completo"
}

> {%
    client.global.set("cartaoId", response.body.id);
    client.log("Cartao ID salvo: " + response.body.id);
%}

### ===================================================
### PASSO 4: TESTES DE TRANSAÇÃO
### ===================================================

### 4.A - Teste de Transação VÁLIDA (Status: COMPLETED)
# (Coordenadas próximas = sem fraude)
POST {{baseUrl}}/api/transacoes
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "valor": 100.50,
    "estabelecimento": "Loja Válida (SP)",
    "cartaoId": {{cartaoId}},
    "latitude": -23.5501,
    "longitude": -46.6499,
    "latitudeUsuario": -23.5510,
    "longitudeUsuario": -46.6500
}

### ---------------------------------------------------

### 4.B - Teste de Transação FRAUDULENTA (Status: PENDING)
# (Coordenadas distantes = fraude de localização)
# @name transacaoPendente
POST {{baseUrl}}/api/transacoes
Authorization: Bearer {{token}}
Content-Type: application/json

{
    "valor": 75.00,
    "estabelecimento": "Loja Fraude (SP vs Salvador)",
    "cartaoId": {{cartaoId}},
    "latitude": -23.5501,
    "longitude": -46.6499,
    "latitudeUsuario": -12.9714,
    "longitudeUsuario": -38.5014
}

> {%
    client.global.set("transacaoId", response.body.transacao.id);
    client.log("Transacao PENDENTE ID salva: " + response.body.transacao.id);
%}

### ---------------------------------------------------

### 4.C - Teste CONFIRMAR Transação Pendente
# (Execute SOMENTE APÓS o 4.B)
POST {{baseUrl}}/api/transacoes/{{transacaoId}}/confirmar
Authorization: Bearer {{token}}

### ---------------------------------------------------

### 4.D - Teste NEGAR Transação Pendente
# (ATENÇÃO: Para testar, rode o 4.B novamente para gerar uma nova
# transação pendente, e SÓ ENTÃO rode este 4.D)
POST {{baseUrl}}/api/transacoes/{{transacaoId}}/negar
Authorization: Bearer {{token}}